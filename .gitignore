# ============================================================

# ─── Dependencias ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build de Next.js ────────────────────────────────────────
.next/
out/
build/
dist/

# ─── TypeScript ──────────────────────────────────────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ─── Variables de entorno y secretos ────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Sistema operativo ───────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editores ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Supabase ────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
