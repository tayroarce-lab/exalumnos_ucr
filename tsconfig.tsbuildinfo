{
  "fileNames": {
    "oneOf": [
      {
        "kind": "directory",
        "value": "C:\\Users\\Forward\\OneDrive\\Desktop\\Exalumnos UCR\\exalumnos_ucr\\src\\app",
        "include": [
          "src/app/(auth)/login/page.tsx",
          "src/app/(auth)/register/page.tsx",
          "src/app/(dashboard)/dashboard/page.tsx",
          "src/app/(dashboard)/mi-perfil/page.tsx",
          "src/app/(dashboard)/vacantes/page.tsx",
          "src/app/(dashboard)/ofertas/page.tsx",
          "src/app/(dashboard)/donaciones/page.tsx",
          "src/app/(dashboard)/reportes/page.tsx",
          "src/app/(dashboard)/admin/page.tsx",
          "src/app/layout.tsx",
          "src/app/page.tsx",
          "src/app/globals.css",
          "src/app/api/cron/check-donations/route.ts",
          "src/app/api/cron/check-matches/route.ts",
          "src/app/api/cron/close-positions/route.ts",
          "src/app/api/auth/signup/route.ts",
          "src/components/LoginForm.tsx",
          "src/components/Navbar.tsx",
          "src/components/VacanteCard.tsx",
          "src/components/DonationCard.tsx",
          "src/app/api/auth/[...nextauth]/route.ts",
          "src/app/(auth)/login/components/LoginForm.tsx",
          "src/app/(auth)/register/components/RegisterForm.tsx",
          "src/app/(dashboard)/dashboard/components/DashboardClient.tsx",
          "src/app/(dashboard)/mi-perfil/components/PerfilClient.tsx",
          "src/app/(dashboard)/vacantes/components/VacantesClient.tsx",
          "src/app/(dashboard)/donaciones/components/DonacionesClient.tsx",
          "src/app/(dashboard)/reportes/components/ReportesClient.tsx",
          "src/app/(dashboard)/admin/components/AdminClient.tsx",
          "src/styles/registerStyles.css"
        ]
      }
    ]
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "webworker"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
